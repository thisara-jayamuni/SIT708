<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary"
    tools:context=".MainActivity">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="32dp"
        android:paddingBottom="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/travel_companion"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:letterSpacing="0.08"
            android:textColor="@color/text_tertiary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/titleTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/unit_converter"
            android:textSize="22sp"
            android:textColor="@color/text_primary" />

    </LinearLayout>

    <View
        android:id="@+id/headerDivider"
        android:layout_width="0dp"
        android:layout_height="0.5dp"
        android:background="@color/divider"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerLayout" />

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerDivider">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="20dp"
            android:paddingBottom="32dp">

            <!-- Category label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/category"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.04"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="8dp" />

            <!-- Category spinner -->
            <Spinner
                android:id="@+id/spinnerCategory"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginBottom="16dp" />

            <!-- Category badge row -->
            <LinearLayout
                android:id="@+id/badgeRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/badgeCurrency"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/badge_currency"
                    android:textSize="12sp"
                    android:background="@drawable/bg_badge"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:layout_marginEnd="8dp"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/badgeFuel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/badge_fuel"
                    android:textSize="12sp"
                    android:background="@drawable/bg_badge"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:layout_marginEnd="8dp"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/badgeTemp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/badge_temp"
                    android:textSize="12sp"
                    android:background="@drawable/bg_badge"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:textColor="@color/text_secondary" />

            </LinearLayout>

            <!-- Source & Destination row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <!-- Source column -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/source"
                        android:textSize="11sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.04"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="8dp" />

                    <Spinner
                        android:id="@+id/sourceCategory"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp" />

                </LinearLayout>

                <!-- Arrow icon -->
                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="10dp"
                    android:layout_marginTop="20dp"
                    android:padding="9dp"
                    android:contentDescription="@string/to" />

                <!-- Destination column -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/destination"
                        android:textSize="11sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.04"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="8dp" />

                    <Spinner
                        android:id="@+id/destinationCategory"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Enter value label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/enter_value"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.04"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="8dp" />

            <!-- Value input -->
            <EditText
                android:id="@+id/etInputValue"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:autofillHints="Enter value"
                android:hint="@string/hint_value"
                android:inputType="numberDecimal|numberSigned"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textSize="20sp"
                android:textColor="@color/input_text"
                android:textColorHint="@color/input_hint"
                android:layout_marginBottom="20dp" />

            <!-- Convert button -->
            <Button
                android:id="@+id/btnConvert"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="@string/convert"
                android:textSize="15sp"
                android:textColor="@color/white"
                android:backgroundTint="@color/button_background"
                android:layout_marginBottom="20dp" />

            <!-- Result card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/converted_result"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.04"
                    android:textColor="@color/text_tertiary"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/tvResult"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/result_placeholder"
                    android:textSize="28sp"
                    android:textColor="@color/card_result_text"
                    android:layout_marginBottom="4dp" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>