<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Title + Category chip row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"/>

            <TextView
                android:id="@+id/tvCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="@drawable/chip_background"
                android:textColor="#0C447C"/>

        </LinearLayout>

        <!-- Date + Location meta row -->
        <TextView
            android:id="@+id/tvMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:textSize="11sp"
            android:textColor="#666666"/>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="8dp"
            android:background="#EFEFEF"/>

        <!-- Edit + Delete buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEdit"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:layout_marginEnd="5dp"
                android:text="Edit"
                android:textSize="11sp"
                android:textColor="#0C447C"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="#85B7EB"
                app:cornerRadius="8dp"
                android:backgroundTint="#E6F1FB"
                app:icon="@drawable/ic_edit"
                app:iconSize="14dp"
                app:iconTint="#0C447C"
                app:iconPadding="4dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDelete"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                android:text="Delete"
                android:textSize="11sp"
                android:textColor="#791F1F"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="#F09595"
                app:cornerRadius="8dp"
                android:backgroundTint="#FCEBEB"
                app:icon="@drawable/ic_delete"
                app:iconSize="14dp"
                app:iconTint="#791F1F"
                app:iconPadding="4dp"/>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
